    "# finetune_timm_512.py\n",
    "import os\n",
    "import json\n",
    "import copy\n",
    "import time\n",
    "import shutil\n",
    "import random\n",
    "import numpy as np\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torchvision import datasets, transforms\n",
    "from torch.utils.data import DataLoader, WeightedRandomSampler\n",
    "\n",
    "import timm\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "\n",
    "# ================= CONFIG =================\n",
    "BASE_PATH = \"get_project_root()"\n",
    "DATA_DIR = os.path.join(BASE_PATH, \"data/02_processed/mobilenet_mf_dataset\")\n",
    "RUN_NAME = \"timm_finetune_512\"\n",
    "OUT_DIR = os.path.join(BASE_PATH, \"outputs\", RUN_NAME)\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "SEED = 42\n",
    "\n",
    "INPUT_SIZE = 512\n",
    "BATCH_SIZE = 4          # 512 -> lourd. Monte si VRAM OK.\n",
    "EPOCHS = 40\n",
    "NUM_WORKERS = 4\n",
    "\n",
    "LABEL_SMOOTHING = 0.05\n",
    "WEIGHT_DECAY = 1e-4\n",
    "LR_HEAD = 5e-4\n",
    "LR_BACKBONE = 1e-5      # plus bas pour éviter de casser le prétraining\n",
    "\n",
    "# Choix modèle timm (exemples robustes)\n",
    "# ConvNeXtV2: \"convnextv2_base\" / \"convnextv2_tiny\"\n",
    "# SwinV2: \"swinv2_tiny_window8_256\" (attention tailles) / \"swinv2_base_window12_192\"\n",
    "# EfficientNetV2: \"tf_efficientnetv2_s\" / \"tf_efficientnetv2_m\"\n",
    "MODEL_NAME = \"convnextv2_tiny\"   # change ici: convnextv2_tiny / swinv2_* / tf_efficientnetv2_*\n",
    "\n",
    "# Unfreeze patterns selon arch (pragmatique)\n",
    "UNFREEZE_PATTERNS = {\n",
    "    \"convnextv2\": [\"stages.3\", \"stages.2\"],       # dernières stages\n",
    "    \"swinv2\": [\"layers.3\", \"layers.2\"],           # dernières layers\n",
    "    \"efficientnetv2\": [\"blocks.5\", \"blocks.6\", \"blocks.7\"]  # fin des blocks\n",
    "}\n",
    "\n",
    "\n",
    "# ================= UTILS =================\n",
    "class ImageFolderWithPaths(datasets.ImageFolder):\n",
    "    def __getitem__(self, idx):\n",
    "        img, label = super().__getitem__(idx)\n",
    "        path, _ = self.samples[idx]\n",
    "        return img, label, path\n",
    "\n",
    "\n",
    "def set_seed(seed=42):\n",
    "    random.seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    torch.manual_seed(seed)\n",
    "    torch.cuda.manual_seed_all(seed)\n",
    "    torch.backends.cudnn.benchmark = True\n",
    "\n",
    "\n",
    "def build_sampler(ds):\n",
    "    targets = [y for _, y in ds.samples]\n",
    "    counts = np.bincount(targets)\n",
    "    w_class = 1.0 / np.maximum(counts, 1)\n",
    "    w_samples = np.array([w_class[t] for t in targets], dtype=np.float64)\n",
    "    sampler = WeightedRandomSampler(\n",
    "        weights=torch.from_numpy(w_samples),\n",
    "        num_samples=len(w_samples),\n",
    "        replacement=True\n",
    "    )\n",
    "    return sampler, counts\n",
    "\n",
    "\n",
    "def plot_cm(y_true, y_pred, class_names, save_path):\n",
    "    cm = confusion_matrix(y_true, y_pred)\n",
    "    plt.figure(figsize=(7, 6))\n",
    "    sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\",\n",
    "                xticklabels=class_names, yticklabels=class_names)\n",
    "    plt.xlabel(\"Pred\")\n",
    "    plt.ylabel(\"True\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(save_path)\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def export_errors(val_paths, y_true, y_pred, out_dir, class_names):\n",
    "    err_dir = os.path.join(out_dir, \"errors_val\")\n",
    "    os.makedirs(err_dir, exist_ok=True)\n",
    "    idxs = np.where(np.array(y_true) != np.array(y_pred))[0]\n",
    "    for i in idxs:\n",
    "        src = val_paths[i]\n",
    "        base = os.path.basename(src)\n",
    "        tag = f\"idx{i}_true-{class_names[y_true[i]]}_pred-{class_names[y_pred[i]]}\"\n",
    "        dst = os.path.join(err_dir, f\"{tag}__{base}\")\n",
    "        shutil.copy2(src, dst)\n",
    "    return err_dir, idxs.tolist()\n",
    "\n",
    "\n",
    "def get_unfreeze_patterns(model_name: str):\n",
    "    name = model_name.lower()\n",
    "    if \"convnextv2\" in name:\n",
    "        return UNFREEZE_PATTERNS[\"convnextv2\"]\n",
    "    if \"swinv2\" in name:\n",
    "        return UNFREEZE_PATTERNS[\"swinv2\"]\n",
    "    if \"efficientnetv2\" in name:\n",
    "        return UNFREEZE_PATTERNS[\"efficientnetv2\"]\n",
    "    # fallback: dégele rien (safe)\n",
    "    return []\n",
    "\n",
    "\n",
    "def freeze_all(model):\n",
    "    for p in model.parameters():\n",
    "        p.requires_grad = False\n",
    "\n",
    "\n",
    "def unfreeze_by_patterns(model, patterns):\n",
    "    for n, p in model.named_parameters():\n",
    "        if any(ptn in n for ptn in patterns):\n",
    "            p.requires_grad = True\n",
    "\n",
    "\n",
    "def main():\n",
    "    set_seed(SEED)\n",
    "    print(\"Device:\", DEVICE)\n",
    "    print(\"Model:\", MODEL_NAME)\n",
    "\n",
    "    # Transforms: garder l’échelle 512 (tu as déjà des 512, donc on évite du crop destructeur)\n",
    "    train_tfm = transforms.Compose([\n",
    "        transforms.Resize((INPUT_SIZE, INPUT_SIZE)),\n",
    "        transforms.RandomHorizontalFlip(p=0.5),\n",
    "        transforms.RandomRotation(10),\n",
    "        transforms.RandomAffine(degrees=0, translate=(0.03, 0.03)),\n",
    "        transforms.ColorJitter(brightness=0.1, contrast=0.1),\n",
    "        transforms.ToTensor(),\n",
    "        transforms.Normalize([0.485, 0.456, 0.406],\n",
    "                             [0.229, 0.224, 0.225]),\n",
    "    ])\n",
    "    val_tfm = transforms.Compose([\n",
    "        transforms.Resize((INPUT_SIZE, INPUT_SIZE)),\n",
    "        transforms.ToTensor(),\n",
    "        transforms.Normalize([0.485, 0.456, 0.406],\n",
    "                             [0.229, 0.224, 0.225]),\n",
    "    ])\n",
    "\n",
    "    ds_train = ImageFolderWithPaths(os.path.join(DATA_DIR, \"train\"), transform=train_tfm)\n",
    "    ds_val = ImageFolderWithPaths(os.path.join(DATA_DIR, \"val\"), transform=val_tfm)\n",
    "    class_names = ds_train.classes\n",
    "    n_classes = len(class_names)\n",
    "    print(\"Classes:\", class_names, \"| train:\", len(ds_train), \"| val:\", len(ds_val))\n",
    "\n",
    "    sampler, counts = build_sampler(ds_train)\n",
    "    print(\"Class counts(train):\", counts, \"(sampler ON)\")\n",
    "\n",
    "    dl_train = DataLoader(ds_train, batch_size=BATCH_SIZE, sampler=sampler,\n",
    "                          num_workers=NUM_WORKERS, pin_memory=True, drop_last=True)\n",
    "    dl_val = DataLoader(ds_val, batch_size=BATCH_SIZE, shuffle=False,\n",
    "                        num_workers=NUM_WORKERS, pin_memory=True)\n",
    "\n",
    "    # Model timm\n",
    "    model = timm.create_model(MODEL_NAME, pretrained=True, num_classes=n_classes)\n",
    "    model = model.to(DEVICE)\n",
    "\n",
    "    # Freeze + unfreeze partiel\n",
    "    freeze_all(model)\n",
    "    patterns = get_unfreeze_patterns(MODEL_NAME)\n",
    "    unfreeze_by_patterns(model, patterns)\n",
    "    # head toujours trainable\n",
    "    for n, p in model.named_parameters():\n",
    "        if \"head\" in n or \"classifier\" in n or \"fc\" in n:\n",
    "            p.requires_grad = True\n",
    "\n",
    "    # Param groups\n",
    "    head_params, backbone_params = [], []\n",
    "    for n, p in model.named_parameters():\n",
    "        if not p.requires_grad:\n",
    "            continue\n",
    "        if (\"head\" in n) or (\"classifier\" in n) or (\"fc\" in n):\n",
    "            head_params.append(p)\n",
    "        else:\n",
    "            backbone_params.append(p)\n",
    "\n",
    "    optimizer = optim.AdamW(\n",
    "        [\n",
    "            {\"params\": backbone_params, \"lr\": LR_BACKBONE},\n",
    "            {\"params\": head_params, \"lr\": LR_HEAD},\n",
    "        ],\n",
    "        weight_decay=WEIGHT_DECAY\n",
    "    )\n",
    "\n",
    "    criterion = nn.CrossEntropyLoss(label_smoothing=LABEL_SMOOTHING)\n",
    "    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode=\"max\",\n",
    "                                                     factor=0.5, patience=6)\n",
    "\n",
    "    best_wts = copy.deepcopy(model.state_dict())\n",
    "    best_acc = -1.0\n",
    "\n",
    "    t0 = time.time()\n",
    "    for epoch in range(EPOCHS):\n",
    "        print(f\"\\nEpoch {epoch+1}/{EPOCHS}\")\n",
    "        # ---- TRAIN ----\n",
    "        model.train()\n",
    "        tr_loss, tr_ok, tr_n = 0.0, 0, 0\n",
    "        for x, y, _p in dl_train:\n",
    "            x = x.to(DEVICE, non_blocking=True)\n",
    "            y = y.to(DEVICE, non_blocking=True)\n",
    "\n",
    "            optimizer.zero_grad(set_to_none=True)\n",
    "            out = model(x)\n",
    "            loss = criterion(out, y)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "\n",
    "            tr_loss += loss.item() * x.size(0)\n",
    "            tr_ok += (out.argmax(1) == y).sum().item()\n",
    "            tr_n += x.size(0)\n",
    "\n",
    "        tr_loss /= max(tr_n, 1)\n",
    "        tr_acc = tr_ok / max(tr_n, 1)\n",
    "\n",
    "        # ---- VAL ----\n",
    "        model.eval()\n",
    "        va_loss, va_ok, va_n = 0.0, 0, 0\n",
    "        y_true, y_pred, val_paths = [], [], []\n",
    "\n",
    "        with torch.no_grad():\n",
    "            for x, y, p in dl_val:\n",
    "                x = x.to(DEVICE, non_blocking=True)\n",
    "                y = y.to(DEVICE, non_blocking=True)\n",
    "                out = model(x)\n",
    "                loss = criterion(out, y)\n",
    "\n",
    "                va_loss += loss.item() * x.size(0)\n",
    "                pred = out.argmax(1)\n",
    "\n",
    "                va_ok += (pred == y).sum().item()\n",
    "                va_n += x.size(0)\n",
    "\n",
    "                y_true.extend(y.cpu().numpy().tolist())\n",
    "                y_pred.extend(pred.cpu().numpy().tolist())\n",
    "                val_paths.extend(list(p))\n",
    "\n",
    "        va_loss /= max(va_n, 1)\n",
    "        va_acc = va_ok / max(va_n, 1)\n",
    "\n",
    "        print(f\"train: loss={tr_loss:.4f} acc={tr_acc:.4f} | val: loss={va_loss:.4f} acc={va_acc:.4f}\")\n",
    "        scheduler.step(va_acc)\n",
    "\n",
    "        if va_acc > best_acc:\n",
    "            best_acc = va_acc\n",
    "            best_wts = copy.deepcopy(model.state_dict())\n",
    "            torch.save(best_wts, os.path.join(OUT_DIR, \"best_model.pth\"))\n",
    "            print(\"⭐ Best saved\")\n",
    "\n",
    "    print(f\"\\nDone in {(time.time()-t0)/60:.1f} min | best_val_acc={best_acc:.4f}\")\n",
    "\n",
    "    # Final eval + reports\n",
    "    model.load_state_dict(best_wts)\n",
    "    model.eval()\n",
    "\n",
    "    y_true, y_pred, val_paths = [], [], []\n",
    "    with torch.no_grad():\n",
    "        for x, y, p in dl_val:\n",
    "            x = x.to(DEVICE, non_blocking=True)\n",
    "            out = model(x)\n",
    "            pred = out.argmax(1)\n",
    "\n",
    "            y_true.extend(y.numpy().tolist())\n",
    "            y_pred.extend(pred.cpu().numpy().tolist())\n",
    "            val_paths.extend(list(p))\n",
    "\n",
    "    report = classification_report(y_true, y_pred, target_names=class_names, zero_division=0)\n",
    "    print(report)\n",
    "    with open(os.path.join(OUT_DIR, \"classification_report.txt\"), \"w\") as f:\n",
    "        f.write(report)\n",
    "\n",
    "    plot_cm(y_true, y_pred, class_names, os.path.join(OUT_DIR, \"confusion_matrix.png\"))\n",
    "    err_dir, err_idxs = export_errors(val_paths, y_true, y_pred, OUT_DIR, class_names)\n",
    "    print(f\"Errors exported to: {err_dir} | n_errors={len(err_idxs)}\")\n",
    "\n",
    "    meta = {\n",
    "        \"model_name\": MODEL_NAME,\n",
    "        \"input_size\": INPUT_SIZE,\n",
    "        \"label_smoothing\": LABEL_SMOOTHING,\n",
    "        \"lr_head\": LR_HEAD,\n",
    "        \"lr_backbone\": LR_BACKBONE,\n",
    "        \"unfreeze_patterns\": patterns,\n",
    "        \"classes\": class_names\n",
    "    }\n",
    "    with open(os.path.join(OUT_DIR, \"meta.json\"), \"w\") as f:\n",
    "        json.dump(meta, f, indent=2)\n",
    "\n",
    "    print(\"Saved to:\", OUT_DIR)\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()\n"
   ]
  },
