   "source": [
    "import os\n",
    "import cv2\n",
    "import glob\n",
    "import numpy as np\n",
    "from ultralytics import YOLO\n",
    "from tqdm import tqdm\n",
    "\n",
    "# ================= CONFIGURATION =================\n",
    "BASE_PATH = \"get_project_root()"\n",
    "\n",
    "SOURCE_DATASET = os.path.join(BASE_PATH, \"data/01_raw/mfi_dataset\")\n",
    "OUTPUT_DATASET = os.path.join(BASE_PATH, \"data/02_processed/mobilenet_mfi_dataset\")\n",
    "\n",
    "# Les couples iront ici (séparé du dataset principal)\n",
    "COUPLES_DATASET = os.path.join(BASE_PATH, \"data/02_processed/couples_mfi_dataset\")\n",
    "\n",
    "MODEL_PATH = os.path.join(BASE_PATH, \"outputs/yolov11n_i1024b2_e100/det/weights/best.pt\")\n",
    "\n",
    "ID_TO_LABEL = {\n",
    "    0: \"male\",\n",
    "    1: \"femelle\",\n",
    "    2: \"indeterminee\",\n",
    "}\n",
    "\n",
    "# Paramètres \"couple\"\n",
    "INTERSECTION_POLICY = \"intersect\"   # \"intersect\" (chevauchement) ou \"iou\"\n",
    "COUPLE_IOU_THRESHOLD = 0.05         # utilisé si policy=\"iou\" (faible pour détecter chevauchement réel)\n",
    "GT_MATCH_IOU_THRESHOLD = 0.40       # mapping det -> GT\n",
    "\n",
    "\n",
    "# ================= FONCTIONS =================\n",
    "def get_ground_truth_boxes(label_path, img_w, img_h):\n",
    "    gt_boxes = []\n",
    "    if not os.path.exists(label_path):\n",
    "        return gt_boxes\n",
    "\n",
    "    with open(label_path, \"r\") as f:\n",
    "        lines = f.readlines()\n",
    "\n",
    "    for line in lines:\n",
    "        parts = line.strip().split()\n",
    "        if len(parts) < 5:\n",
    "            continue\n",
    "\n",
    "        cls_id = int(parts[0])\n",
    "        x_c, y_c, w, h = map(float, parts[1:5])\n",
    "\n",
    "        x1 = int((x_c - w / 2) * img_w)\n",
    "        y1 = int((y_c - h / 2) * img_h)\n",
    "        x2 = int((x_c + w / 2) * img_w)\n",
    "        y2 = int((y_c + h / 2) * img_h)\n",
    "\n",
    "        gt_boxes.append({\"bbox\": [x1, y1, x2, y2], \"class_id\": cls_id})\n",
    "\n",
    "    return gt_boxes\n",
    "\n",
    "\n",
    "def compute_iou(boxA, boxB):\n",
    "    xA = max(boxA[0], boxB[0])\n",
    "    yA = max(boxA[1], boxB[1])\n",
    "    xB = min(boxA[2], boxB[2])\n",
    "    yB = min(boxA[3], boxB[3])\n",
    "\n",
    "    interArea = max(0, xB - xA) * max(0, yB - yA)\n",
    "    boxAArea = max(0, boxA[2] - boxA[0]) * max(0, boxA[3] - boxA[1])\n",
    "    boxBArea = max(0, boxB[2] - boxB[0]) * max(0, boxB[3] - boxB[1])\n",
    "\n",
    "    return interArea / float(boxAArea + boxBArea - interArea + 1e-6)\n",
    "\n",
    "\n",
    "def boxes_intersect(boxA, boxB):\n",
    "    xA = max(boxA[0], boxB[0])\n",
    "    yA = max(boxA[1], boxB[1])\n",
    "    xB = min(boxA[2], boxB[2])\n",
    "    yB = min(boxA[3], boxB[3])\n",
    "    return (xB > xA) and (yB > yA)\n",
    "\n",
    "\n",
    "def merge_boxes(boxA, boxB):\n",
    "    x1 = min(boxA[0], boxB[0])\n",
    "    y1 = min(boxA[1], boxB[1])\n",
    "    x2 = max(boxA[2], boxB[2])\n",
    "    y2 = max(boxA[3], boxB[3])\n",
    "    return [x1, y1, x2, y2]\n",
    "\n",
    "\n",
    "def is_couple_pair(boxA, boxB):\n",
    "    if INTERSECTION_POLICY == \"intersect\":\n",
    "        return boxes_intersect(boxA, boxB)\n",
    "    elif INTERSECTION_POLICY == \"iou\":\n",
    "        return compute_iou(boxA, boxB) >= COUPLE_IOU_THRESHOLD\n",
    "    else:\n",
    "        raise ValueError(\"INTERSECTION_POLICY must be 'intersect' or 'iou'\")\n",
    "\n",
    "\n",
    "def save_crop_512(img, box, save_path):\n",
    "    CANVAS_SIZE = 512\n",
    "    x1, y1, x2, y2 = box\n",
    "\n",
    "    x1_c, y1_c = max(0, x1), max(0, y1)\n",
    "    x2_c, y2_c = min(img.shape[1], x2), min(img.shape[0], y2)\n",
    "\n",
    "    crop = img[y1_c:y2_c, x1_c:x2_c]\n",
    "    if crop.size == 0:\n",
    "        return False\n",
    "\n",
    "    h_c, w_c = crop.shape[:2]\n",
    "    if h_c == 0 or w_c == 0:\n",
    "        return False\n",
    "\n",
    "    if h_c > CANVAS_SIZE or w_c > CANVAS_SIZE:\n",
    "        scale = CANVAS_SIZE / max(h_c, w_c)\n",
    "        new_w, new_h = int(w_c * scale), int(h_c * scale)\n",
    "        crop = cv2.resize(crop, (new_w, new_h), interpolation=cv2.INTER_AREA)\n",
    "\n",
    "    h_f, w_f = crop.shape[:2]\n",
    "    canvas = np.zeros((CANVAS_SIZE, CANVAS_SIZE, 3), dtype=np.uint8)\n",
    "\n",
    "    pad_x = (CANVAS_SIZE - w_f) // 2\n",
    "    pad_y = (CANVAS_SIZE - h_f) // 2\n",
    "\n",
    "    canvas[pad_y:pad_y + h_f, pad_x:pad_x + w_f] = crop\n",
    "    cv2.imwrite(save_path, canvas)\n",
    "    return True\n",
    "\n",
    "\n",
    "# ================= MAIN =================\n",
    "def main():\n",
    "    if not os.path.exists(MODEL_PATH):\n",
    "        print(f\"❌ ERREUR : Modèle introuvable à {MODEL_PATH}\")\n",
    "        return\n",
    "\n",
    "    model = YOLO(MODEL_PATH)\n",
    "\n",
    "    for split in [\"train\", \"val\"]:\n",
    "        print(f\"\\n--- Traitement : {split.upper()} ---\")\n",
    "\n",
    "        img_dir = os.path.join(SOURCE_DATASET, split, \"images\")\n",
    "        lbl_dir = os.path.join(SOURCE_DATASET, split, \"labels\")\n",
    "\n",
    "        images = glob.glob(os.path.join(img_dir, \"*.png\")) + glob.glob(os.path.join(img_dir, \"*.jpg\"))\n",
    "\n",
    "        n_saved_main = 0\n",
    "        n_saved_couples = 0\n",
    "        n_skipped = 0\n",
    "\n",
    "        for img_path in tqdm(images):\n",
    "            filename = os.path.splitext(os.path.basename(img_path))[0]\n",
    "            label_path = os.path.join(lbl_dir, filename + \".txt\")\n",
    "\n",
    "            img = cv2.imread(img_path)\n",
    "            if img is None:\n",
    "                n_skipped += 1\n",
    "                continue\n",
    "\n",
    "            h_img, w_img = img.shape[:2]\n",
    "            gt_boxes = get_ground_truth_boxes(label_path, w_img, h_img)\n",
    "            if not gt_boxes:\n",
    "                continue\n",
    "\n",
    "            # YOLO inference\n",
    "            results = model.predict(img_path, conf=0.25, iou=0.6, verbose=False)\n",
    "\n",
    "            detected_boxes_raw = []\n",
    "            for r in results:\n",
    "                detected_boxes_raw = r.boxes.xyxy.cpu().numpy().astype(int).tolist()\n",
    "\n",
    "            if not detected_boxes_raw:\n",
    "                continue\n",
    "\n",
    "            # --- Fusion + marquage couple ---\n",
    "            final_detections = []  # list of dict: {\"bbox\":..., \"is_couple\": bool}\n",
    "            while detected_boxes_raw:\n",
    "                curr = detected_boxes_raw.pop(0)\n",
    "                is_couple = False\n",
    "\n",
    "                merged = True\n",
    "                while merged:\n",
    "                    merged = False\n",
    "                    rest = []\n",
    "                    for other in detected_boxes_raw:\n",
    "                        if is_couple_pair(curr, other):\n",
    "                            curr = merge_boxes(curr, other)\n",
    "                            merged = True\n",
    "                            is_couple = True\n",
    "                        else:\n",
    "                            rest.append(other)\n",
    "                    detected_boxes_raw = rest\n",
    "\n",
    "                final_detections.append({\"bbox\": curr, \"is_couple\": is_couple})\n",
    "\n",
    "            # --- Mapping det -> GT + Save ---\n",
    "            for idx, det in enumerate(final_detections):\n",
    "                det_box = det[\"bbox\"]\n",
    "                is_couple = det[\"is_couple\"]\n",
    "\n",
    "                best_iou = 0.0\n",
    "                assigned_label = None\n",
    "                for gt in gt_boxes:\n",
    "                    iou = compute_iou(det_box, gt[\"bbox\"])\n",
    "                    if iou > best_iou:\n",
    "                        best_iou = iou\n",
    "                        assigned_label = gt[\"class_id\"]\n",
    "\n",
    "                # doit matcher une GT\n",
    "                if best_iou < GT_MATCH_IOU_THRESHOLD or assigned_label is None:\n",
    "                    continue\n",
    "\n",
    "                class_name = ID_TO_LABEL.get(assigned_label, \"unknown\")\n",
    "\n",
    "                # Si couple détecté -> on met dans COUPLES_DATASET (et on ne pollue pas le dataset principal)\n",
    "                if is_couple:\n",
    "                    save_dir = os.path.join(COUPLES_DATASET, split, \"couple\")\n",
    "                    os.makedirs(save_dir, exist_ok=True)\n",
    "                    save_name = f\"{filename}_couple{idx}.png\"\n",
    "                    save_full_path = os.path.join(save_dir, save_name)\n",
    "                    if save_crop_512(img, det_box, save_full_path):\n",
    "                        n_saved_couples += 1\n",
    "                    continue\n",
    "\n",
    "                # Sinon : dataset principal (male/femelle/indeterminee si tu veux)\n",
    "                if class_name == \"unknown\":\n",
    "                    continue\n",
    "\n",
    "                save_dir = os.path.join(OUTPUT_DATASET, split, class_name)\n",
    "                os.makedirs(save_dir, exist_ok=True)\n",
    "\n",
    "                save_name = f\"{filename}_crop{idx}.png\"\n",
    "                save_full_path = os.path.join(save_dir, save_name)\n",
    "                if save_crop_512(img, det_box, save_full_path):\n",
    "                    n_saved_main += 1\n",
    "\n",
    "        print(f\"[{split}] saved_main={n_saved_main} | saved_couples={n_saved_couples} | skipped={n_skipped}\")\n",
    "\n",
    "    print(\"\\n✅ Génération terminée.\")\n",
    "    print(f\"Dataset principal: {OUTPUT_DATASET}\")\n",
    "    print(\"  ├── train/{male,femelle,indeterminee}/\")\n",
    "    print(\"  └── val/{male,femelle,indeterminee}/\")\n",
    "    print(f\"Dataset couples:  {COUPLES_DATASET}\")\n",
    "    print(\"  ├── train/couple/\")\n",
    "    print(\"  └── val/couple/\")\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()\n"
   ]
  }
 ],
