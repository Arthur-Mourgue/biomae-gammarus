   "source": [
    "# train_clip_sklearn.py\n",
    "import os\n",
    "import json\n",
    "import shutil\n",
    "import numpy as np\n",
    "import torch\n",
    "from torch.utils.data import DataLoader\n",
    "from torchvision import datasets, transforms\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.svm import SVC\n",
    "from sklearn.neural_network import MLPClassifier\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "\n",
    "import open_clip\n",
    "import joblib\n",
    "\n",
    "\n",
    "# ================= CONFIG =================\n",
    "BASE_PATH = \"get_project_root()"\n",
    "DATA_DIR = os.path.join(BASE_PATH, \"data/02_processed/mobilenet_dataset\")\n",
    "RUN_NAME = \"clip_embeddings_sklearn\"\n",
    "OUT_DIR = os.path.join(BASE_PATH, \"outputs\", RUN_NAME)\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "BATCH_SIZE = 32\n",
    "NUM_WORKERS = 4\n",
    "\n",
    "# CLIP model choices: (\"ViT-B-32\", \"openai\") / (\"ViT-L-14\", \"openai\") / (\"ViT-H-14\", \"laion2b_s32b_b79k\") etc.\n",
    "CLIP_ARCH = \"ViT-L-14\"\n",
    "CLIP_PRETRAIN = \"openai\"\n",
    "\n",
    "# CLASSIFIER: \"logreg\" / \"svm\" / \"mlp\"\n",
    "CLASSIFIER = \"logreg\"\n",
    "\n",
    "CACHE_NPZ = os.path.join(OUT_DIR, \"embeddings_cache.npz\")\n",
    "\n",
    "\n",
    "# ================= UTILS =================\n",
    "class ImageFolderWithPaths(datasets.ImageFolder):\n",
    "    def __getitem__(self, idx):\n",
    "        img, label = super().__getitem__(idx)\n",
    "        path, _ = self.samples[idx]\n",
    "        return img, label, path\n",
    "\n",
    "\n",
    "def plot_cm(y_true, y_pred, class_names, save_path):\n",
    "    cm = confusion_matrix(y_true, y_pred)\n",
    "    plt.figure(figsize=(7, 6))\n",
    "    sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\",\n",
    "                xticklabels=class_names, yticklabels=class_names)\n",
    "    plt.xlabel(\"Pred\")\n",
    "    plt.ylabel(\"True\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(save_path)\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def export_errors(paths, y_true, y_pred, out_dir, class_names):\n",
    "    err_dir = os.path.join(out_dir, \"errors_val\")\n",
    "    os.makedirs(err_dir, exist_ok=True)\n",
    "    idxs = np.where(np.array(y_true) != np.array(y_pred))[0]\n",
    "    for i in idxs:\n",
    "        src = paths[i]\n",
    "        base = os.path.basename(src)\n",
    "        tag = f\"idx{i}_true-{class_names[y_true[i]]}_pred-{class_names[y_pred[i]]}\"\n",
    "        dst = os.path.join(err_dir, f\"{tag}__{base}\")\n",
    "        shutil.copy2(src, dst)\n",
    "    return err_dir, idxs.tolist()\n",
    "\n",
    "\n",
    "def build_classifier(kind: str):\n",
    "    if kind == \"logreg\":\n",
    "        clf = LogisticRegression(max_iter=5000, class_weight=\"balanced\", n_jobs=-1)\n",
    "    elif kind == \"svm\":\n",
    "        clf = SVC(kernel=\"rbf\", class_weight=\"balanced\", probability=True)\n",
    "    elif kind == \"mlp\":\n",
    "        clf = MLPClassifier(hidden_layer_sizes=(256, 64), alpha=1e-4,\n",
    "                            max_iter=2000, early_stopping=True)\n",
    "    else:\n",
    "        raise ValueError(\"CLASSIFIER must be: logreg/svm/mlp\")\n",
    "\n",
    "    return Pipeline([\n",
    "        (\"scaler\", StandardScaler()),\n",
    "        (\"clf\", clf)\n",
    "    ])\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def extract_embeddings(model, loader):\n",
    "    model.eval()\n",
    "    feats, labels, paths = [], [], []\n",
    "\n",
    "    for images, y, p in loader:\n",
    "        images = images.to(DEVICE, non_blocking=True)\n",
    "        emb = model.encode_image(images)\n",
    "        emb = emb / emb.norm(dim=-1, keepdim=True)  # normalisation CLIP\n",
    "        feats.append(emb.detach().cpu().numpy())\n",
    "        labels.extend(y.numpy().tolist())\n",
    "        paths.extend(list(p))\n",
    "\n",
    "    feats = np.concatenate(feats, axis=0)\n",
    "    return feats, np.array(labels, dtype=int), np.array(paths)\n",
    "\n",
    "\n",
    "def main():\n",
    "    print(\"Device:\", DEVICE)\n",
    "\n",
    "    # Load CLIP + preprocessing\n",
    "    model, _, preprocess = open_clip.create_model_and_transforms(\n",
    "        CLIP_ARCH, pretrained=CLIP_PRETRAIN\n",
    "    )\n",
    "    model = model.to(DEVICE)\n",
    "\n",
    "    # Dataset via preprocess CLIP (gère resize/crop selon arch)\n",
    "    ds_train = ImageFolderWithPaths(os.path.join(DATA_DIR, \"train\"), transform=preprocess)\n",
    "    ds_val = ImageFolderWithPaths(os.path.join(DATA_DIR, \"val\"), transform=preprocess)\n",
    "    class_names = ds_train.classes\n",
    "    print(\"Classes:\", class_names)\n",
    "\n",
    "    dl_train = DataLoader(ds_train, batch_size=BATCH_SIZE, shuffle=False,\n",
    "                          num_workers=NUM_WORKERS, pin_memory=True)\n",
    "    dl_val = DataLoader(ds_val, batch_size=BATCH_SIZE, shuffle=False,\n",
    "                        num_workers=NUM_WORKERS, pin_memory=True)\n",
    "\n",
    "    if os.path.exists(CACHE_NPZ):\n",
    "        print(\"Loading cached embeddings:\", CACHE_NPZ)\n",
    "        data = np.load(CACHE_NPZ, allow_pickle=True)\n",
    "        X_train, y_train, p_train = data[\"X_train\"], data[\"y_train\"], data[\"p_train\"]\n",
    "        X_val, y_val, p_val = data[\"X_val\"], data[\"y_val\"], data[\"p_val\"]\n",
    "    else:\n",
    "        print(\"Extracting embeddings (train)...\")\n",
    "        X_train, y_train, p_train = extract_embeddings(model, dl_train)\n",
    "        print(\"Extracting embeddings (val)...\")\n",
    "        X_val, y_val, p_val = extract_embeddings(model, dl_val)\n",
    "        np.savez_compressed(CACHE_NPZ,\n",
    "                            X_train=X_train, y_train=y_train, p_train=p_train,\n",
    "                            X_val=X_val, y_val=y_val, p_val=p_val)\n",
    "        print(\"Saved cache:\", CACHE_NPZ)\n",
    "\n",
    "    clf = build_classifier(CLASSIFIER)\n",
    "    print(\"Training classifier:\", CLASSIFIER)\n",
    "    clf.fit(X_train, y_train)\n",
    "\n",
    "    y_pred = clf.predict(X_val)\n",
    "    report = classification_report(y_val, y_pred, target_names=class_names, zero_division=0)\n",
    "    print(report)\n",
    "    with open(os.path.join(OUT_DIR, \"classification_report.txt\"), \"w\") as f:\n",
    "        f.write(report)\n",
    "\n",
    "    plot_cm(y_val, y_pred, class_names, os.path.join(OUT_DIR, \"confusion_matrix.png\"))\n",
    "    err_dir, err_idxs = export_errors(p_val, y_val, y_pred, OUT_DIR, class_names)\n",
    "    print(f\"Errors exported to: {err_dir} | n_errors={len(err_idxs)}\")\n",
    "\n",
    "    meta = {\n",
    "        \"clip_arch\": CLIP_ARCH,\n",
    "        \"clip_pretrain\": CLIP_PRETRAIN,\n",
    "        \"classifier\": CLASSIFIER,\n",
    "        \"classes\": class_names\n",
    "    }\n",
    "    with open(os.path.join(OUT_DIR, \"meta.json\"), \"w\") as f:\n",
    "        json.dump(meta, f, indent=2)\n",
    "\n",
    "    joblib.dump(clf, os.path.join(OUT_DIR, \"sk_model.joblib\"))\n",
