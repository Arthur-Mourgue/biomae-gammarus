   "source": [
    "import os\n",
    "import copy\n",
    "import time\n",
    "import json\n",
    "import random\n",
    "import shutil\n",
    "\n",
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torchvision import datasets, models, transforms\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.metrics import confusion_matrix, classification_report, f1_score, balanced_accuracy_score\n",
    "\n",
    "\n",
    "# ================= CONFIGURATION =================\n",
    "BASE_PATH = \"get_project_root()"\n",
    "DATA_DIR = os.path.join(BASE_PATH, \"data/02_processed/mobilenet_mfc_dataset\")\n",
    "RUN_NAME = \"mobilenet_v3_mfc_3classes_512\"\n",
    "OUTPUT_DIR = os.path.join(BASE_PATH, \"outputs\", RUN_NAME)\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "BATCH_SIZE = 8          # si OOM -> 4 ou 2\n",
    "NUM_EPOCHS = 150\n",
    "INPUT_SIZE = 512        # ✅ images 512x512\n",
    "NUM_WORKERS = 4\n",
    "SEED = 42\n",
    "\n",
    "# Fine-tuning\n",
    "UNFREEZE_LAST_N_FEATURE_BLOCKS = 3\n",
    "LR_HEAD = 5e-4\n",
    "LR_BACKBONE = 1e-4\n",
    "WEIGHT_DECAY = 1e-4\n",
    "\n",
    "# Déséquilibre\n",
    "USE_WEIGHTED_SAMPLER = True\n",
    "USE_WEIGHTED_CE = False  # si sampler OFF, tu peux mettre True\n",
    "\n",
    "# Décision: argmax recommandé\n",
    "USE_ARGMAX_DECISION = True\n",
    "\n",
    "# Règle à seuils optionnelle (priorité couple -> femelle -> male)\n",
    "USE_THRESHOLD_DECISION = False\n",
    "THRESHOLD_COUPLE = 0.50\n",
    "THRESHOLD_FEMALE = 0.40\n",
    "\n",
    "# Régularisation\n",
    "USE_LABEL_SMOOTHING = True\n",
    "LABEL_SMOOTHING = 0.05\n",
    "\n",
    "\n",
    "# ================= OUTILS =================\n",
    "def set_seed(seed: int = 42):\n",
    "    random.seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    torch.manual_seed(seed)\n",
    "    torch.cuda.manual_seed_all(seed)\n",
    "    torch.backends.cudnn.deterministic = False\n",
    "    torch.backends.cudnn.benchmark = True\n",
    "\n",
    "\n",
    "def plot_history(history, save_path):\n",
    "    fig, ax = plt.subplots(1, 2, figsize=(15, 6))\n",
    "\n",
    "    ax[0].plot(history[\"train_loss\"], label=\"Train Loss\")\n",
    "    ax[0].plot(history[\"val_loss\"], label=\"Val Loss\")\n",
    "    ax[0].set_title(\"Loss\")\n",
    "    ax[0].set_xlabel(\"Epochs\")\n",
    "    ax[0].set_ylabel(\"Loss\")\n",
    "    ax[0].legend()\n",
    "    ax[0].grid(True)\n",
    "\n",
    "    ax[1].plot(history[\"train_acc\"], label=\"Train Acc (argmax)\")\n",
    "    ax[1].plot(history[\"val_acc\"], label=\"Val Acc (decision)\")\n",
    "    ax[1].plot(history[\"val_bal_acc\"], label=\"Val Balanced Acc\")\n",
    "    ax[1].plot(history[\"val_f1_macro\"], label=\"Val F1 Macro\")\n",
    "    ax[1].set_title(\"Metrics\")\n",
    "    ax[1].set_xlabel(\"Epochs\")\n",
    "    ax[1].set_ylabel(\"Score\")\n",
    "    ax[1].legend()\n",
    "    ax[1].grid(True)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(os.path.join(save_path, \"results.png\"))\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def plot_confusion_matrix(y_true, y_pred, classes, save_path):\n",
    "    cm = confusion_matrix(y_true, y_pred, labels=list(range(len(classes))))\n",
    "    cm_norm = cm.astype(np.float64) / np.maximum(cm.sum(axis=1, keepdims=True), 1.0)\n",
    "\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\",\n",
    "                xticklabels=classes, yticklabels=classes)\n",
    "    plt.ylabel(\"Vraie Classe\")\n",
    "    plt.xlabel(\"Classe Prédite\")\n",
    "    plt.title(\"Matrice de Confusion (brute)\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(os.path.join(save_path, \"confusion_matrix.png\"))\n",
    "    plt.close()\n",
    "\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    sns.heatmap(cm_norm, annot=True, fmt=\".2f\", cmap=\"Blues\",\n",
    "                vmin=0.0, vmax=1.0,\n",
    "                xticklabels=classes, yticklabels=classes)\n",
    "    plt.ylabel(\"Vraie Classe\")\n",
    "    plt.xlabel(\"Classe Prédite\")\n",
    "    plt.title(\"Matrice de Confusion (normalisée par vraie classe)\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(os.path.join(save_path, \"confusion_matrix_normalized.png\"))\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def build_weighted_sampler(image_folder_dataset):\n",
    "    targets = [y for _, y in image_folder_dataset.samples]\n",
    "    class_count = np.bincount(targets)\n",
    "    class_weight = 1.0 / np.maximum(class_count, 1)\n",
    "    sample_weights = np.array([class_weight[t] for t in targets], dtype=np.float64)\n",
    "    sample_weights = torch.from_numpy(sample_weights)\n",
    "\n",
    "    sampler = torch.utils.data.WeightedRandomSampler(\n",
    "        weights=sample_weights,\n",
    "        num_samples=len(sample_weights),\n",
    "        replacement=True,\n",
    "    )\n",
    "    return sampler, class_count\n",
    "\n",
    "\n",
    "class ImageFolderWithPaths(datasets.ImageFolder):\n",
    "    def __getitem__(self, index):\n",
    "        img, label = super().__getitem__(index)\n",
    "        path, _ = self.samples[index]\n",
    "        return img, label, path\n",
    "\n",
    "\n",
    "def predict_with_thresholds_3(probs, idx_c, idx_f, idx_m, thr_c, thr_f, labels_like):\n",
    "    p_c = probs[:, idx_c]\n",
    "    p_f = probs[:, idx_f]\n",
    "\n",
    "    pred = torch.full_like(labels_like, fill_value=idx_m)  # défaut male\n",
    "    pred = torch.where(p_f >= thr_f, torch.full_like(pred, idx_f), pred)\n",
    "    pred = torch.where(p_c >= thr_c, torch.full_like(pred, idx_c), pred)\n",
    "    return pred\n",
    "\n",
    "\n",
    "def get_backbone_out_features_mnv3(model, input_size: int) -> int:\n",
    "    # méthode robuste : premier Linear du classifier d'origine => in_features (=960 en large)\n",
    "    if hasattr(model, \"classifier\") and isinstance(model.classifier, nn.Sequential):\n",
    "        for layer in model.classifier:\n",
    "            if isinstance(layer, nn.Linear):\n",
    "                return layer.in_features\n",
    "\n",
    "    # fallback\n",
    "    with torch.no_grad():\n",
    "        x = torch.zeros(1, 3, input_size, input_size)\n",
    "        x = model.features(x)\n",
    "        x = model.avgpool(x)\n",
    "        x = torch.flatten(x, 1)\n",
    "        return int(x.shape[1])\n",
    "\n",
    "\n",
    "# ================= MAIN =================\n",
    "def main():\n",
    "    set_seed(SEED)\n",
    "    device = torch.device(\"cuda:0\" if torch.cuda.is_available() else \"cpu\")\n",
    "    print(f\"Device: {device}\")\n",
    "\n",
    "    # 1) Transforms (✅ 512x512)\n",
    "    data_transforms = {\n",
    "        \"train\": transforms.Compose([\n",
    "            transforms.Resize((INPUT_SIZE, INPUT_SIZE)),\n",
    "            transforms.RandomHorizontalFlip(p=0.5),\n",
    "            transforms.RandomRotation(15),\n",
    "            transforms.RandomAffine(degrees=0, translate=(0.05, 0.05)),\n",
    "            transforms.ColorJitter(brightness=0.1, contrast=0.1),\n",
    "            transforms.ToTensor(),\n",
    "            transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),\n",
    "        ]),\n",
    "        \"val\": transforms.Compose([\n",
    "            transforms.Resize((INPUT_SIZE, INPUT_SIZE)),\n",
    "            transforms.ToTensor(),\n",
    "            transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),\n",
    "        ]),\n",
    "    }\n",
    "\n",
    "    # 2) Datasets\n",
    "    image_datasets = {\n",
    "        x: ImageFolderWithPaths(os.path.join(DATA_DIR, x), data_transforms[x])\n",
    "        for x in [\"train\", \"val\"]\n",
    "    }\n",
    "\n",
    "    class_names = image_datasets[\"train\"].classes\n",
    "    num_classes = len(class_names)\n",
    "    dataset_sizes = {x: len(image_datasets[x]) for x in [\"train\", \"val\"]}\n",
    "\n",
    "    print(f\"Classes: {class_names}\")\n",
    "    print(f\"Train size: {dataset_sizes['train']} | Val size: {dataset_sizes['val']}\")\n",
    "\n",
    "    class_to_idx = image_datasets[\"train\"].class_to_idx\n",
    "    print(\"class_to_idx:\", class_to_idx)\n",
    "\n",
    "    IDX_C = class_to_idx.get(\"couple\", None)\n",
    "    IDX_F = class_to_idx.get(\"femelle\", None)\n",
    "    IDX_M = class_to_idx.get(\"male\", None)\n",
    "\n",
    "    if num_classes != 3:\n",
    "        raise ValueError(f\"Dataset attendu en 3 classes (couple/femelle/male), trouvé {num_classes}, classes={class_names}.\")\n",
    "    if any(v is None for v in [IDX_C, IDX_F, IDX_M]):\n",
    "        raise ValueError(f\"Classes attendues: couple, femelle, male. Trouvé: {list(class_to_idx.keys())}.\")\n",
    "\n",
    "    # 3) Sampler pondéré\n",
    "    train_sampler = None\n",
    "    class_count = None\n",
    "\n",
    "    if USE_WEIGHTED_SAMPLER:\n",
    "        train_sampler, class_count = build_weighted_sampler(image_datasets[\"train\"])\n",
    "        print(f\"Class counts (train): {class_count} (sampler ON)\")\n",
    "    else:\n",
    "        targets = [y for _, y in image_datasets[\"train\"].samples]\n",
    "        class_count = np.bincount(targets)\n",
    "        print(f\"Class counts (train): {class_count} (sampler OFF)\")\n",
    "\n",
    "    # 4) Dataloaders\n",
    "    dataloaders = {\n",
    "        \"train\": torch.utils.data.DataLoader(\n",
    "            image_datasets[\"train\"],\n",
    "            batch_size=BATCH_SIZE,\n",
    "            shuffle=(train_sampler is None),\n",
    "            sampler=train_sampler,\n",
    "            num_workers=NUM_WORKERS,\n",
    "            drop_last=False,  # ✅ métriques propres\n",
    "            pin_memory=True,\n",
    "        ),\n",
    "        \"val\": torch.utils.data.DataLoader(\n",
    "            image_datasets[\"val\"],\n",
    "            batch_size=BATCH_SIZE,\n",
    "            shuffle=False,\n",
    "            num_workers=NUM_WORKERS,\n",
    "            drop_last=False,\n",
    "            pin_memory=True,\n",
    "        ),\n",
    "    }\n",
    "\n",
    "    # 5) Modèle + head (✅ robuste, pas de mismatch 960/1280)\n",
    "    model = models.mobilenet_v3_large(weights=models.MobileNet_V3_Large_Weights.DEFAULT)\n",
    "\n",
    "    for p in model.parameters():\n",
    "        p.requires_grad = False\n",
    "\n",
    "    if UNFREEZE_LAST_N_FEATURE_BLOCKS > 0:\n",
    "        for p in model.features[-UNFREEZE_LAST_N_FEATURE_BLOCKS:].parameters():\n",
    "            p.requires_grad = True\n",
    "\n",
    "    backbone_out = get_backbone_out_features_mnv3(model, INPUT_SIZE)\n",
    "    print(f\"[DEBUG] backbone_out_features={backbone_out}\")\n",
    "\n",
    "    model.classifier = nn.Sequential(\n",
    "        nn.Linear(backbone_out, 512),\n",
    "        nn.LayerNorm(512),\n",
    "        nn.ReLU(inplace=True),\n",
    "        nn.Dropout(0.5),\n",
    "        nn.Linear(512, num_classes),\n",
    "    )\n",
    "    model = model.to(device)\n",
    "\n",
    "    # 6) Loss\n",
    "    if USE_LABEL_SMOOTHING:\n",
    "        criterion = nn.CrossEntropyLoss(label_smoothing=LABEL_SMOOTHING)\n",
    "        print(f\"Loss: CrossEntropy + label_smoothing={LABEL_SMOOTHING}\")\n",
    "    else:\n",
    "        if USE_WEIGHTED_CE and (not USE_WEIGHTED_SAMPLER):\n",
    "            counts = class_count.astype(np.float32)\n",
    "            w = 1.0 / np.maximum(counts, 1.0)\n",
    "            w = w / w.sum() * len(w)\n",
    "            class_weights = torch.tensor(w, dtype=torch.float32, device=device)\n",
    "            criterion = nn.CrossEntropyLoss(weight=class_weights)\n",
    "            print(f\"Loss: Weighted CE ON | weights={w}\")\n",
    "        else:\n",
    "            criterion = nn.CrossEntropyLoss()\n",
    "            print(\"Loss: CrossEntropy standard\")\n",
    "\n",
    "    # 7) Optimiseur\n",
    "    head_params = list(model.classifier.parameters())\n",
    "    backbone_params = [p for n, p in model.named_parameters()\n",
    "                       if p.requires_grad and (not n.startswith(\"classifier.\"))]\n",
    "\n",
    "    optimizer = optim.AdamW(\n",
    "        [{\"params\": backbone_params, \"lr\": LR_BACKBONE},\n",
    "         {\"params\": head_params, \"lr\": LR_HEAD}],\n",
    "        weight_decay=WEIGHT_DECAY,\n",
    "    )\n",
    "\n",
    "    scheduler = optim.lr_scheduler.ReduceLROnPlateau(\n",
    "        optimizer, mode=\"max\", factor=0.5, patience=8\n",
    "    )\n",
    "\n",
    "    # 8) Entraînement\n",
    "    since = time.time()\n",
    "    best_model_wts = copy.deepcopy(model.state_dict())\n",
    "    best_score = -1.0\n",
    "\n",
    "    best_meta = {\n",
    "        \"best_epoch\": None,\n",
    "        \"best_val_f1_macro\": None,\n",
    "        \"best_val_bal_acc\": None,\n",
    "        \"best_val_acc\": None,\n",
    "        \"use_argmax_decision\": bool(USE_ARGMAX_DECISION),\n",
    "        \"use_threshold_decision\": bool(USE_THRESHOLD_DECISION),\n",
    "        \"threshold_female\": float(THRESHOLD_FEMALE),\n",
    "        \"threshold_couple\": float(THRESHOLD_COUPLE),\n",
    "        \"class_names\": class_names,\n",
    "        \"class_to_idx\": class_to_idx,\n",
    "        \"notes\": \"Best model selected on F1-macro (3 classes). Input size 512.\",\n",
    "    }\n",
    "\n",
    "    history = {\n",
    "        \"train_loss\": [],\n",
    "        \"val_loss\": [],\n",
    "        \"train_acc\": [],\n",
    "        \"val_acc\": [],\n",
    "        \"val_bal_acc\": [],\n",
    "        \"val_f1_macro\": [],\n",
    "    }\n",
    "\n",
    "    for epoch in range(NUM_EPOCHS):\n",
    "        print(f\"\\nEpoch {epoch+1}/{NUM_EPOCHS}\")\n",
    "        print(\"-\" * 40)\n",
    "\n",
    "        for phase in [\"train\", \"val\"]:\n",
    "            model.train() if phase == \"train\" else model.eval()\n",
    "\n",
    "            running_loss = 0.0\n",
    "            running_corrects = 0\n",
    "            seen = 0\n",
    "\n",
    "            y_true_epoch, y_pred_epoch = [], []\n",
    "\n",
    "            for inputs, labels, _paths in dataloaders[phase]:\n",
    "                inputs = inputs.to(device, non_blocking=True)\n",
    "                labels = labels.to(device, non_blocking=True)\n",
    "\n",
    "                optimizer.zero_grad(set_to_none=True)\n",
    "\n",
    "                with torch.set_grad_enabled(phase == \"train\"):\n",
    "                    outputs = model(inputs)\n",
    "                    loss = criterion(outputs, labels)\n",
    "                    if phase == \"train\":\n",
    "                        loss.backward()\n",
    "                        optimizer.step()\n",
    "\n",
    "                bs = inputs.size(0)\n",
    "                seen += bs\n",
    "                running_loss += loss.item() * bs\n",
    "\n",
    "                if phase == \"train\":\n",
    "                    _, preds = torch.max(outputs, 1)\n",
    "                    running_corrects += torch.sum(preds == labels.data).item()\n",
    "                else:\n",
    "                    if USE_ARGMAX_DECISION or (not USE_THRESHOLD_DECISION):\n",
    "                        _, preds_decision = torch.max(outputs, 1)\n",
    "                    else:\n",
    "                        probs = torch.softmax(outputs, dim=1)\n",
    "                        preds_decision = predict_with_thresholds_3(\n",
    "                            probs, IDX_C, IDX_F, IDX_M, THRESHOLD_COUPLE, THRESHOLD_FEMALE, labels\n",
    "                        )\n",
    "\n",
    "                    running_corrects += torch.sum(preds_decision == labels.data).item()\n",
    "                    y_true_epoch.extend(labels.detach().cpu().numpy().tolist())\n",
    "                    y_pred_epoch.extend(preds_decision.detach().cpu().numpy().tolist())\n",
    "\n",
    "            epoch_loss = running_loss / max(seen, 1)\n",
    "            epoch_acc = running_corrects / max(seen, 1)\n",
    "\n",
    "            if phase == \"train\":\n",
    "                history[\"train_loss\"].append(epoch_loss)\n",
    "                history[\"train_acc\"].append(epoch_acc)\n",
    "                print(f\"train | loss={epoch_loss:.4f} acc={epoch_acc:.4f}\")\n",
    "            else:\n",
    "                y_true_np = np.array(y_true_epoch, dtype=int)\n",
    "                y_pred_np = np.array(y_pred_epoch, dtype=int)\n",
    "\n",
    "                val_bal_acc = balanced_accuracy_score(y_true_np, y_pred_np)\n",
    "                val_f1_macro = f1_score(y_true_np, y_pred_np, average=\"macro\", zero_division=0)\n",
    "\n",
    "                history[\"val_loss\"].append(epoch_loss)\n",
    "                history[\"val_acc\"].append(epoch_acc)\n",
    "                history[\"val_bal_acc\"].append(val_bal_acc)\n",
    "                history[\"val_f1_macro\"].append(val_f1_macro)\n",
    "\n",
    "                decision_str = \"argmax\" if (USE_ARGMAX_DECISION or not USE_THRESHOLD_DECISION) else \\\n",
    "                    f\"thr_c={THRESHOLD_COUPLE}, thr_f={THRESHOLD_FEMALE}\"\n",
    "\n",
    "                print(\n",
    "                    f\"val   | loss={epoch_loss:.4f} acc={epoch_acc:.4f} \"\n",
    "                    f\"bal_acc={val_bal_acc:.4f} f1_macro={val_f1_macro:.4f} decision={decision_str}\"\n",
    "                )\n",
    "\n",
    "                scheduler.step(val_f1_macro)\n",
    "\n",
    "                if val_f1_macro > best_score:\n",
    "                    best_score = float(val_f1_macro)\n",
    "                    best_model_wts = copy.deepcopy(model.state_dict())\n",
    "                    torch.save(best_model_wts, os.path.join(OUTPUT_DIR, \"best_model.pth\"))\n",
    "\n",
    "                    best_meta.update({\n",
    "                        \"best_epoch\": epoch + 1,\n",
    "                        \"best_val_f1_macro\": float(val_f1_macro),\n",
    "                        \"best_val_bal_acc\": float(val_bal_acc),\n",
    "                        \"best_val_acc\": float(epoch_acc),\n",
    "                    })\n",
    "                    with open(os.path.join(OUTPUT_DIR, \"best_meta.json\"), \"w\") as f:\n",
    "                        json.dump(best_meta, f, indent=2)\n",
    "\n",
    "                    print(\"⭐ Best model saved\")\n",
    "\n",
    "    time_elapsed = time.time() - since\n",
    "    print(f\"\\nTraining complete in {time_elapsed/60:.1f} min\")\n",
    "    print(f\"Best F1(macro) = {best_score:.4f}\")\n",
    "    print(\"Best meta:\", best_meta)\n",
    "\n",
    "    # 9) Évaluation finale + export erreurs\n",
    "    print(\"\\n--- ÉVALUATION FINALE ---\")\n",
    "    model.load_state_dict(best_model_wts)\n",
    "    model.eval()\n",
    "\n",
    "    y_true, y_pred, y_probs, val_paths = [], [], [], []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for inputs, labels, paths in dataloaders[\"val\"]:\n",
    "            inputs = inputs.to(device, non_blocking=True)\n",
    "            labels = labels.to(device, non_blocking=True)\n",
    "\n",
    "            outputs = model(inputs)\n",
    "            probs = torch.softmax(outputs, dim=1)\n",
    "\n",
    "            if USE_ARGMAX_DECISION or (not USE_THRESHOLD_DECISION):\n",
    "                _, preds_decision = torch.max(outputs, 1)\n",
    "            else:\n",
    "                preds_decision = predict_with_thresholds_3(\n",
    "                    probs, IDX_C, IDX_F, IDX_M, THRESHOLD_COUPLE, THRESHOLD_FEMALE, labels\n",
    "                )\n",
    "\n",
    "            y_true.extend(labels.cpu().numpy().tolist())\n",
    "            y_pred.extend(preds_decision.cpu().numpy().tolist())\n",
    "            y_probs.extend(probs.cpu().numpy().tolist())\n",
    "            val_paths.extend(list(paths))\n",
    "\n",
    "    plot_confusion_matrix(y_true, y_pred, class_names, OUTPUT_DIR)\n",
    "\n",
    "    report = classification_report(y_true, y_pred, target_names=class_names, zero_division=0)\n",
    "    with open(os.path.join(OUTPUT_DIR, \"classification_report.txt\"), \"w\") as f:\n",
    "        f.write(report)\n",
    "    print(report)\n",
    "\n",
    "    plot_history(history, OUTPUT_DIR)\n",
    "\n",
    "    y_true = np.array(y_true, dtype=int)\n",
    "    y_pred = np.array(y_pred, dtype=int)\n",
    "    y_probs = np.array(y_probs, dtype=float)\n",
    "\n",
    "    errors = np.where(y_true != y_pred)[0]\n",
    "    print(f\"Nb erreurs val: {len(errors)} / {len(y_true)}\")\n",
    "\n",
    "    errors_dir = os.path.join(OUTPUT_DIR, \"errors_val\")\n",
    "    os.makedirs(errors_dir, exist_ok=True)\n",
    "\n",
    "    for i in errors:\n",
    "        src = val_paths[i]\n",
    "        true_cls = class_names[y_true[i]]\n",
    "        pred_cls = class_names[y_pred[i]]\n",
    "\n",
    "        conf = y_probs[i][y_pred[i]] * 100\n",
    "        pc = y_probs[i][IDX_C] * 100\n",
    "        pf = y_probs[i][IDX_F] * 100\n",
    "        pm = y_probs[i][IDX_M] * 100\n",
    "\n",
    "        base = os.path.basename(src)\n",
    "        tag = f\"idx{i}_true-{true_cls}_pred-{pred_cls}_conf{conf:.1f}_Pc{pc:.1f}_Pf{pf:.1f}_Pm{pm:.1f}\"\n",
    "        dst = os.path.join(errors_dir, f\"{tag}__{base}\")\n",
    "        shutil.copy2(src, dst)\n",
    "\n",
    "        print(\n",
    "            f\"  ❌ idx={i} | vrai={true_cls} | pred={pred_cls} | \"\n",
    "            f\"conf={conf:.2f}% | Pc={pc:.2f}% | Pf={pf:.2f}% | Pm={pm:.2f}%\"\n",
    "        )\n",
    "\n",
    "    print(f\"\\nErreurs copiées dans: {errors_dir}\")\n",
    "    print(f\"Tout est sauvegardé dans: {OUTPUT_DIR}\")\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()\n"
   ]
  },
