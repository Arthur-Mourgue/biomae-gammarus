   "source": [
    "# ============================================================\n",
    "# SigLIP2 (ViT) - Classification 3 classes - 512x512 - NO RESIZE\n",
    "# - Backbone vision-only (évite le tour texte => moins de VRAM)\n",
    "# - Fallback OOM: backbone CPU + head GPU (si backbone gelé)\n",
    "# ============================================================\n",
    "\n",
    "import os\n",
    "import copy\n",
    "import time\n",
    "import json\n",
    "import random\n",
    "import shutil\n",
    "import warnings\n",
    "\n",
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torchvision import datasets, transforms\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.metrics import confusion_matrix, classification_report, f1_score, balanced_accuracy_score\n",
    "\n",
    "from transformers import AutoProcessor, AutoConfig\n",
    "\n",
    "# --------- Optionnel mais utile contre fragmentation CUDA ----------\n",
    "# (à mettre avant le premier gros load CUDA; dans un notebook, relance le kernel)\n",
    "os.environ.setdefault(\"PYTORCH_CUDA_ALLOC_CONF\", \"expandable_segments:True\")\n",
    "\n",
    "# ================= CONFIGURATION =================\n",
    "BASE_PATH = \"get_project_root()"\n",
    "DATA_DIR = os.path.join(BASE_PATH, \"data/02_processed/mobilenet_mfi_dataset\")\n",
    "\n",
    "RUN_NAME = \"siglip2_visiononly_512_noresize_mfi\"\n",
    "OUTPUT_DIR = os.path.join(BASE_PATH, \"outputs\", RUN_NAME)\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "# Modèle open\n",
    "CKPT = \"google/siglip2-base-patch16-512\"\n",
    "\n",
    "# Data\n",
    "INPUT_SIZE = 512  # STRICT: pas de resize autorisé\n",
    "BATCH_SIZE = 2    # commence bas pour 7-8Go VRAM; tu peux monter si VRAM libre\n",
    "NUM_EPOCHS = 100\n",
    "NUM_WORKERS = 4\n",
    "SEED = 42\n",
    "\n",
    "# Fine-tuning\n",
    "FREEZE_BACKBONE = True               # RECOMMANDÉ petit dataset\n",
    "UNFREEZE_LAST_N_BLOCKS = 0           # >0 possible seulement si backbone sur GPU (pas en fallback CPU)\n",
    "LR_HEAD = 5e-4\n",
    "LR_BACKBONE = 1e-5\n",
    "WEIGHT_DECAY = 1e-4\n",
    "\n",
    "# Déséquilibre\n",
    "USE_WEIGHTED_SAMPLER = True\n",
    "USE_WEIGHTED_CE = False  # si sampler OFF, tu peux activer\n",
    "\n",
    "# Règle de décision à seuils (3 classes)\n",
    "THRESHOLD_FEMALE = 0.40\n",
    "THRESHOLD_INDET = 0.50\n",
    "USE_ARGMAX_DECISION = False\n",
    "\n",
    "# Régularisation\n",
    "USE_LABEL_SMOOTHING = True\n",
    "LABEL_SMOOTHING = 0.05\n",
    "\n",
    "# Perf/mémoire\n",
    "USE_AMP = True  # autocast fp16 sur GPU\n",
    "TORCH_DTYPE_ON_GPU = torch.float16   # réduit VRAM (poids + activations)\n",
    "PIN_MEMORY = True\n",
    "\n",
    "\n",
    "# ================= OUTILS =================\n",
    "def set_seed(seed: int = 42):\n",
    "    random.seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    torch.manual_seed(seed)\n",
    "    torch.cuda.manual_seed_all(seed)\n",
    "    torch.backends.cudnn.deterministic = False\n",
    "    torch.backends.cudnn.benchmark = True\n",
    "\n",
    "\n",
    "def plot_history(history, save_path):\n",
    "    fig, ax = plt.subplots(1, 2, figsize=(15, 6))\n",
    "\n",
    "    ax[0].plot(history[\"train_loss\"], label=\"Train Loss\")\n",
    "    ax[0].plot(history[\"val_loss\"], label=\"Val Loss\")\n",
    "    ax[0].set_title(\"Loss\")\n",
    "    ax[0].set_xlabel(\"Epochs\")\n",
    "    ax[0].set_ylabel(\"Loss\")\n",
    "    ax[0].legend()\n",
    "    ax[0].grid(True)\n",
    "\n",
    "    ax[1].plot(history[\"train_acc\"], label=\"Train Acc (argmax)\")\n",
    "    ax[1].plot(history[\"val_acc\"], label=\"Val Acc (decision)\")\n",
    "    ax[1].plot(history[\"val_bal_acc\"], label=\"Val Balanced Acc\")\n",
    "    ax[1].plot(history[\"val_f1_female\"], label=\"Val F1 (femelle)\")\n",
    "    ax[1].set_title(\"Metrics\")\n",
    "    ax[1].set_xlabel(\"Epochs\")\n",
    "    ax[1].set_ylabel(\"Score\")\n",
    "    ax[1].legend()\n",
    "    ax[1].grid(True)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(os.path.join(save_path, \"results.png\"))\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def plot_confusion_matrix(y_true, y_pred, classes, save_path):\n",
    "    cm = confusion_matrix(y_true, y_pred, labels=list(range(len(classes))))\n",
    "    cm_norm = cm.astype(np.float64) / np.maximum(cm.sum(axis=1, keepdims=True), 1.0)\n",
    "\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\", xticklabels=classes, yticklabels=classes)\n",
    "    plt.ylabel(\"Vraie Classe\")\n",
    "    plt.xlabel(\"Classe Prédite\")\n",
    "    plt.title(\"Matrice de Confusion (brute)\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(os.path.join(save_path, \"confusion_matrix.png\"))\n",
    "    plt.close()\n",
    "\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    sns.heatmap(cm_norm, annot=True, fmt=\".2f\", cmap=\"Blues\", vmin=0.0, vmax=1.0,\n",
    "                xticklabels=classes, yticklabels=classes)\n",
    "    plt.ylabel(\"Vraie Classe\")\n",
    "    plt.xlabel(\"Classe Prédite\")\n",
    "    plt.title(\"Matrice de Confusion (normalisée par vraie classe)\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(os.path.join(save_path, \"confusion_matrix_normalized.png\"))\n",
    "    plt.close()\n",
    "\n",
    "\n",
    "def build_weighted_sampler(image_folder_dataset):\n",
    "    targets = [y for _, y in image_folder_dataset.samples]\n",
    "    class_count = np.bincount(targets)\n",
    "    class_weight = 1.0 / np.maximum(class_count, 1)\n",
    "    sample_weights = np.array([class_weight[t] for t in targets], dtype=np.float64)\n",
    "    sample_weights = torch.from_numpy(sample_weights)\n",
    "    sampler = torch.utils.data.WeightedRandomSampler(weights=sample_weights,\n",
    "                                                     num_samples=len(sample_weights),\n",
    "                                                     replacement=True)\n",
    "    return sampler, class_count\n",
    "\n",
    "\n",
    "class ImageFolderWithPaths(datasets.ImageFolder):\n",
    "    \"\"\"Retourne (image_tensor, label, path).\"\"\"\n",
    "    def __getitem__(self, index):\n",
    "        img, label = super().__getitem__(index)\n",
    "        path, _ = self.samples[index]\n",
    "        return img, label, path\n",
    "\n",
    "\n",
    "class AssertSquareSize:\n",
    "    \"\"\"Fail fast si l'image n'est pas exactement size x size. Aucun resize autorisé.\"\"\"\n",
    "    def __init__(self, size: int):\n",
    "        self.size = int(size)\n",
    "\n",
    "    def __call__(self, img):\n",
    "        w, h = img.size  # PIL\n",
    "        if (w != self.size) or (h != self.size):\n",
    "            raise ValueError(\n",
    "                f\"Image attendue: {self.size}x{self.size}. Obtenu: {w}x{h}. \"\n",
    "                \"Aucun resize/crop autorisé.\"\n",
    "            )\n",
    "        return img\n",
    "\n",
    "\n",
    "def predict_with_thresholds(probs, idx_f, idx_m, idx_i, thr_f, thr_i, labels_like):\n",
    "    # 1) indet si P(indet) >= thr_i\n",
    "    # 2) sinon femelle si P(femelle) >= thr_f\n",
    "    # 3) sinon male\n",
    "    p_f = probs[:, idx_f]\n",
    "    p_i = probs[:, idx_i]\n",
    "    pred = torch.full_like(labels_like, fill_value=idx_m)\n",
    "    pred = torch.where(p_f >= thr_f, torch.full_like(pred, idx_f), pred)\n",
    "    pred = torch.where(p_i >= thr_i, torch.full_like(pred, idx_i), pred)\n",
    "    return pred\n",
    "\n",
    "\n",
    "def freeze_all(module: nn.Module):\n",
    "    for p in module.parameters():\n",
    "        p.requires_grad = False\n",
    "\n",
    "\n",
    "def unfreeze_last_n_transformer_blocks(vision_model: nn.Module, n_last: int):\n",
    "    \"\"\"\n",
    "    Best-effort: essaye d'identifier les blocks ViT (layers/blocks) et dégèle les n derniers.\n",
    "    Si ça ne matche pas ta version Transformers, on n'échoue pas.\n",
    "    \"\"\"\n",
    "    if n_last <= 0:\n",
    "        return\n",
    "\n",
    "    # structures possibles selon versions\n",
    "    candidates = []\n",
    "    for path in [\"encoder.layers\", \"encoder.layer\", \"encoder.blocks\", \"layers\", \"layer\", \"blocks\"]:\n",
    "        cur = vision_model\n",
    "        ok = True\n",
    "        for key in path.split(\".\"):\n",
    "            if not hasattr(cur, key):\n",
    "                ok = False\n",
    "                break\n",
    "            cur = getattr(cur, key)\n",
    "        if ok:\n",
    "            candidates.append(cur)\n",
    "\n",
    "    if not candidates:\n",
    "        print(\"[WARN] Impossible d'identifier les blocks du ViT: unfreeze partiel ignoré.\")\n",
    "        return\n",
    "\n",
    "    layers = candidates[0]\n",
    "    try:\n",
    "        tail = list(layers)[-n_last:]\n",
    "    except Exception:\n",
    "        print(\"[WARN] Blocks non itérables: unfreeze partiel ignoré.\")\n",
    "        return\n",
    "\n",
    "    for blk in tail:\n",
    "        for p in blk.parameters():\n",
    "            p.requires_grad = True\n",
    "    print(f\"Backbone vision: unfreeze last {n_last} block(s) (best-effort).\")\n",
    "\n",
    "\n",
    "# ================= MODELE =================\n",
    "class SigLIP2VisionOnlyClassifier(nn.Module):\n",
    "    \"\"\"\n",
    "    Vision encoder + head MLP.\n",
    "    Supporte mode hybride: backbone_device != head_device (OK seulement si backbone gelé).\n",
    "    \"\"\"\n",
    "    def __init__(self, vision_backbone: nn.Module, num_classes: int, input_size: int,\n",
    "                 backbone_device: torch.device, head_device: torch.device):\n",
    "        super().__init__()\n",
    "        self.vision = vision_backbone\n",
    "        self.backbone_device = backbone_device\n",
    "        self.head_device = head_device\n",
    "\n",
    "        # infère emb_dim via un dummy forward (sur backbone_device)\n",
    "        self.vision.eval()\n",
    "        with torch.no_grad():\n",
    "            dummy = torch.zeros(1, 3, input_size, input_size, dtype=torch.float32, device=backbone_device)\n",
    "            out = self.vision(pixel_values=dummy)\n",
    "            if hasattr(out, \"pooler_output\") and out.pooler_output is not None:\n",
    "                feats = out.pooler_output\n",
    "            else:\n",
    "                feats = out.last_hidden_state[:, 0]\n",
    "            emb_dim = int(feats.shape[-1])\n",
    "\n",
    "        self.head = nn.Sequential(\n",
    "            nn.Linear(emb_dim, 512),\n",
    "            nn.LayerNorm(512),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(0.5),\n",
    "            nn.Linear(512, num_classes),\n",
    "        ).to(head_device)\n",
    "\n",
    "    def forward(self, x):\n",
    "        # x peut être sur CPU ou GPU ; on l'envoie au backbone_device\n",
    "        if x.device != self.backbone_device:\n",
    "            x_b = x.to(self.backbone_device, non_blocking=True)\n",
    "        else:\n",
    "            x_b = x\n",
    "\n",
    "        backbone_frozen = not any(p.requires_grad for p in self.vision.parameters())\n",
    "\n",
    "        if backbone_frozen:\n",
    "            with torch.no_grad():\n",
    "                out = self.vision(pixel_values=x_b)\n",
    "                if hasattr(out, \"pooler_output\") and out.pooler_output is not None:\n",
    "                    feats = out.pooler_output\n",
    "                else:\n",
    "                    feats = out.last_hidden_state[:, 0]\n",
    "        else:\n",
    "            out = self.vision(pixel_values=x_b)\n",
    "            feats = out.pooler_output if (hasattr(out, \"pooler_output\") and out.pooler_output is not None) else out.last_hidden_state[:, 0]\n",
    "\n",
    "        if feats.device != self.head_device:\n",
    "            feats = feats.to(self.head_device, non_blocking=True)\n",
    "\n",
    "        return self.head(feats)\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "def load_vision_backbone(ckpt: str, device: torch.device, dtype_on_gpu: torch.dtype):\n",
    "    \"\"\"\n",
    "    Charge un backbone vision-only (évite de charger le texte).\n",
    "    Compatible SigLIP / SigLIP2 selon config.model_type.\n",
    "    \"\"\"\n",
    "    cfg = AutoConfig.from_pretrained(ckpt)\n",
    "    model_type = getattr(cfg, \"model_type\", \"\")\n",
    "\n",
    "    kwargs = dict(low_cpu_mem_usage=True)\n",
    "    if device.type == \"cuda\":\n",
    "        kwargs[\"torch_dtype\"] = dtype_on_gpu\n",
    "\n",
    "    # Imports conditionnels pour compat version Transformers\n",
    "    if model_type == \"siglip2\":\n",
    "        try:\n",
    "            from transformers import Siglip2VisionModel\n",
    "            vision = Siglip2VisionModel.from_pretrained(ckpt, **kwargs)\n",
    "        except Exception as e:\n",
    "            raise RuntimeError(f\"Siglip2VisionModel introuvable/KO sur ta version Transformers: {e}\")\n",
    "    elif model_type == \"siglip\":\n",
    "        try:\n",
    "            from transformers import SiglipVisionModel\n",
    "            vision = SiglipVisionModel.from_pretrained(ckpt, **kwargs)\n",
    "        except Exception as e:\n",
    "            raise RuntimeError(f\"SiglipVisionModel introuvable/KO sur ta version Transformers: {e}\")\n",
    "    else:\n",
    "        # dernier recours: tente vision-only via AutoModel\n",
    "        from transformers import AutoModel\n",
    "        vision = AutoModel.from_pretrained(ckpt, **kwargs)\n",
    "\n",
    "    return vision\n",
    "\n",
    "\n",
    "# ================= MAIN =================\n",
    "def main():\n",
    "    warnings.filterwarnings(\"ignore\")\n",
    "    set_seed(SEED)\n",
    "\n",
    "    device = torch.device(\"cuda:0\" if torch.cuda.is_available() else \"cpu\")\n",
    "    print(f\"Device détecté: {device}\")\n",
    "\n",
    "    # Processor pour mean/std (on n'utilise PAS processor(images=...) => pas de resize/crop)\n",
    "    processor = AutoProcessor.from_pretrained(CKPT)\n",
    "    img_proc = getattr(processor, \"image_processor\", None)\n",
    "    if img_proc is None:\n",
    "        raise RuntimeError(\"AutoProcessor ne fournit pas image_processor sur ce checkpoint.\")\n",
    "    mean = img_proc.image_mean\n",
    "    std = img_proc.image_std\n",
    "    print(f\"Normalisation: mean={mean} std={std}\")\n",
    "\n",
    "    # 1) Transforms (NO RESIZE)\n",
    "    data_transforms = {\n",
    "        \"train\": transforms.Compose([\n",
    "            AssertSquareSize(INPUT_SIZE),\n",
    "            transforms.RandomHorizontalFlip(p=0.5),\n",
    "            transforms.RandomRotation(15),\n",
    "            transforms.RandomAffine(degrees=0, translate=(0.05, 0.05)),\n",
    "            transforms.ColorJitter(brightness=0.1, contrast=0.1),\n",
    "            transforms.ToTensor(),\n",
    "            transforms.Normalize(mean, std),\n",
    "        ]),\n",
    "        \"val\": transforms.Compose([\n",
    "            AssertSquareSize(INPUT_SIZE),\n",
    "            transforms.ToTensor(),\n",
    "            transforms.Normalize(mean, std),\n",
    "        ]),\n",
    "    }\n",
    "\n",
    "    # 2) Datasets\n",
    "    image_datasets = {\n",
    "        x: ImageFolderWithPaths(os.path.join(DATA_DIR, x), data_transforms[x])\n",
    "        for x in [\"train\", \"val\"]\n",
    "    }\n",
    "\n",
    "    class_names = image_datasets[\"train\"].classes\n",
    "    num_classes = len(class_names)\n",
    "    dataset_sizes = {x: len(image_datasets[x]) for x in [\"train\", \"val\"]}\n",
    "\n",
    "    print(f\"Classes: {class_names}\")\n",
    "    print(f\"Train size: {dataset_sizes['train']} | Val size: {dataset_sizes['val']}\")\n",
    "\n",
    "    class_to_idx = image_datasets[\"train\"].class_to_idx\n",
    "    print(\"class_to_idx:\", class_to_idx)\n",
    "\n",
    "    # Dataset attendu en 3 classes\n",
    "    IDX_F = class_to_idx.get(\"femelle\", None)\n",
    "    IDX_M = class_to_idx.get(\"male\", None)\n",
    "    IDX_I = class_to_idx.get(\"indeterminee\", None)\n",
    "    if num_classes != 3 or IDX_F is None or IDX_M is None or IDX_I is None:\n",
    "        raise ValueError(\n",
    "            \"Dataset attendu: 3 classes avec dossiers EXACTS: femelle / male / indeterminee. \"\n",
    "            f\"Trouvé: {list(class_to_idx.keys())}\"\n",
    "        )\n",
    "\n",
    "    # 3) Sampler pondéré\n",
    "    train_sampler = None\n",
    "    if USE_WEIGHTED_SAMPLER:\n",
    "        train_sampler, class_count = build_weighted_sampler(image_datasets[\"train\"])\n",
    "        print(f\"Class counts (train): {class_count} (sampler ON)\")\n",
    "    else:\n",
    "        targets = [y for _, y in image_datasets[\"train\"].samples]\n",
    "        class_count = np.bincount(targets)\n",
    "        print(f\"Class counts (train): {class_count} (sampler OFF)\")\n",
    "\n",
    "    # 4) Dataloaders\n",
    "    dataloaders = {\n",
    "        \"train\": torch.utils.data.DataLoader(\n",
    "            image_datasets[\"train\"],\n",
    "            batch_size=BATCH_SIZE,\n",
    "            shuffle=(train_sampler is None),\n",
    "            sampler=train_sampler,\n",
    "            num_workers=NUM_WORKERS,\n",
    "            drop_last=True,\n",
    "            pin_memory=PIN_MEMORY,\n",
    "        ),\n",
    "        \"val\": torch.utils.data.DataLoader(\n",
    "            image_datasets[\"val\"],\n",
    "            batch_size=BATCH_SIZE,\n",
    "            shuffle=False,\n",
    "            num_workers=NUM_WORKERS,\n",
    "            pin_memory=PIN_MEMORY,\n",
    "        ),\n",
    "    }\n",
    "\n",
    "    # 5) Modèle: charge vision-only\n",
    "    #    Stratégie:\n",
    "    #    - tente backbone sur GPU (fp16) si possible\n",
    "    #    - si OOM => backbone CPU, head GPU (uniquement si backbone gelé)\n",
    "    backbone_device = device\n",
    "    head_device = device\n",
    "\n",
    "    try:\n",
    "        vision = load_vision_backbone(CKPT, device=device, dtype_on_gpu=TORCH_DTYPE_ON_GPU)\n",
    "        vision = vision.to(backbone_device)\n",
    "    except torch.cuda.OutOfMemoryError:\n",
    "        print(\"\\n[OOM] VRAM insuffisante pour charger le backbone sur GPU.\")\n",
    "        print(\"      => Fallback: backbone sur CPU, head sur GPU (OK seulement si backbone gelé).\")\n",
    "        torch.cuda.empty_cache()\n",
    "        if not FREEZE_BACKBONE:\n",
    "            raise RuntimeError(\"Fallback CPU/GPU impossible si FREEZE_BACKBONE=False (backprop multi-device).\")\n",
    "        backbone_device = torch.device(\"cpu\")\n",
    "        head_device = torch.device(\"cuda:0\") if torch.cuda.is_available() else torch.device(\"cpu\")\n",
    "        vision = load_vision_backbone(CKPT, device=torch.device(\"cpu\"), dtype_on_gpu=TORCH_DTYPE_ON_GPU)\n",
    "        vision = vision.to(backbone_device)\n",
    "\n",
    "    # wrap + head\n",
    "    model = SigLIP2VisionOnlyClassifier(\n",
    "        vision_backbone=vision,\n",
    "        num_classes=num_classes,\n",
    "        input_size=INPUT_SIZE,\n",
    "        backbone_device=backbone_device,\n",
    "        head_device=head_device,\n",
    "    )\n",
    "\n",
    "    # freeze/unfreeze\n",
    "    if FREEZE_BACKBONE:\n",
    "        freeze_all(model.vision)\n",
    "        print(\"Backbone: FROZEN\")\n",
    "    if UNFREEZE_LAST_N_BLOCKS > 0:\n",
    "        if backbone_device.type != \"cuda\":\n",
    "            raise RuntimeError(\"UNFREEZE_LAST_N_BLOCKS>0 nécessite backbone sur GPU (pas en fallback CPU).\")\n",
    "        unfreeze_last_n_transformer_blocks(model.vision, UNFREEZE_LAST_N_BLOCKS)\n",
    "\n",
    "    # AMP scaler (uniquement si head_device est cuda)\n",
    "    use_amp = USE_AMP and (head_device.type == \"cuda\")\n",
    "    scaler = torch.cuda.amp.GradScaler(enabled=use_amp)\n",
    "\n",
    "    # 6) Loss\n",
    "    if USE_LABEL_SMOOTHING:\n",
    "        criterion = nn.CrossEntropyLoss(label_smoothing=LABEL_SMOOTHING)\n",
    "        print(f\"Loss: CrossEntropy + label_smoothing={LABEL_SMOOTHING}\")\n",
    "    else:\n",
    "        if USE_WEIGHTED_CE and (not USE_WEIGHTED_SAMPLER):\n",
    "            counts = class_count.astype(np.float32)\n",
    "            w = 1.0 / np.maximum(counts, 1.0)\n",
    "            w = w / w.sum() * len(w)\n",
    "            class_weights = torch.tensor(w, dtype=torch.float32, device=head_device)\n",
    "            criterion = nn.CrossEntropyLoss(weight=class_weights)\n",
    "            print(f\"Loss: Weighted CE ON | weights={w}\")\n",
    "        else:\n",
    "            criterion = nn.CrossEntropyLoss()\n",
    "            print(\"Loss: CrossEntropy standard\")\n",
    "\n",
    "    # 7) Optimiseur\n",
    "    head_params = list(model.head.parameters())\n",
    "    backbone_params = [p for p in model.vision.parameters() if p.requires_grad]\n",
    "\n",
    "    optimizer = optim.AdamW(\n",
    "        [{\"params\": backbone_params, \"lr\": LR_BACKBONE},\n",
    "         {\"params\": head_params, \"lr\": LR_HEAD}],\n",
    "        weight_decay=WEIGHT_DECAY,\n",
    "    )\n",
    "    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode=\"max\", factor=0.5, patience=8)\n",
    "\n",
    "    # 8) Entraînement\n",
    "    since = time.time()\n",
    "    best_model_wts = copy.deepcopy(model.state_dict())\n",
    "    best_score = -1.0\n",
    "\n",
    "    best_meta = {\n",
    "        \"best_epoch\": None,\n",
    "        \"best_val_f1_female\": None,\n",
    "        \"best_val_bal_acc\": None,\n",
    "        \"best_val_acc\": None,\n",
    "        \"threshold_female\": float(THRESHOLD_FEMALE),\n",
    "        \"threshold_indet\": float(THRESHOLD_INDET),\n",
    "        \"use_argmax_decision\": bool(USE_ARGMAX_DECISION),\n",
    "        \"class_names\": class_names,\n",
    "        \"class_to_idx\": class_to_idx,\n",
    "        \"ckpt\": CKPT,\n",
    "        \"input_size\": INPUT_SIZE,\n",
    "        \"backbone_device\": str(backbone_device),\n",
    "        \"head_device\": str(head_device),\n",
    "        \"notes\": \"SigLIP2 vision-only + MLP head. NO RESIZE. Best model selected on F1(femelle).\",\n",
    "    }\n",
    "\n",
    "    history = {\n",
    "        \"train_loss\": [], \"val_loss\": [],\n",
    "        \"train_acc\": [], \"val_acc\": [],\n",
    "        \"val_bal_acc\": [], \"val_f1_female\": [],\n",
    "    }\n",
    "\n",
    "    for epoch in range(NUM_EPOCHS):\n",
    "        print(f\"\\nEpoch {epoch+1}/{NUM_EPOCHS}\")\n",
    "        print(\"-\" * 40)\n",
    "\n",
    "        for phase in [\"train\", \"val\"]:\n",
    "            model.train() if phase == \"train\" else model.eval()\n",
    "\n",
    "            running_loss = 0.0\n",
    "            running_corrects = 0\n",
    "\n",
    "            y_true_epoch, y_pred_epoch = [], []\n",
    "\n",
    "            for inputs, labels, _paths in dataloaders[phase]:\n",
    "                # inputs sur head_device (la head décide le flux)\n",
    "                inputs = inputs.to(backbone_device, non_blocking=True)\n",
    "                labels = labels.to(head_device, non_blocking=True)\n",
    "\n",
    "\n",
    "                optimizer.zero_grad(set_to_none=True)\n",
    "\n",
    "                # si backbone gelé, on évite de stocker des grads côté backbone\n",
    "                grad_enabled = (phase == \"train\")\n",
    "                with torch.set_grad_enabled(grad_enabled):\n",
    "                    # autocast uniquement sur GPU head\n",
    "                    with torch.cuda.amp.autocast(enabled=use_amp):\n",
    "                        # si backbone gelé, on force no_grad autour du backbone (évite activations)\n",
    "                        outputs = model(inputs)  # pas de no_grad ici\n",
    "\n",
    "\n",
    "                        loss = criterion(outputs, labels)\n",
    "\n",
    "                    if phase == \"train\":\n",
    "                        if use_amp:\n",
    "                            scaler.scale(loss).backward()\n",
    "                            scaler.step(optimizer)\n",
    "                            scaler.update()\n",
    "                        else:\n",
    "                            loss.backward()\n",
    "                            optimizer.step()\n",
    "\n",
    "                running_loss += loss.item() * inputs.size(0)\n",
    "\n",
    "                if phase == \"train\":\n",
    "                    _, preds_argmax = torch.max(outputs, 1)\n",
    "                    running_corrects += torch.sum(preds_argmax == labels.data).item()\n",
    "                else:\n",
    "                    if USE_ARGMAX_DECISION:\n",
    "                        _, preds_decision = torch.max(outputs, 1)\n",
    "                    else:\n",
    "                        probs = torch.softmax(outputs, dim=1)\n",
    "                        preds_decision = predict_with_thresholds(\n",
    "                            probs, IDX_F, IDX_M, IDX_I, THRESHOLD_FEMALE, THRESHOLD_INDET, labels\n",
    "                        )\n",
    "                    running_corrects += torch.sum(preds_decision == labels.data).item()\n",
    "                    y_true_epoch.extend(labels.detach().cpu().numpy().tolist())\n",
    "                    y_pred_epoch.extend(preds_decision.detach().cpu().numpy().tolist())\n",
    "\n",
    "            epoch_loss = running_loss / dataset_sizes[phase]\n",
    "            epoch_acc = running_corrects / dataset_sizes[phase]\n",
    "\n",
    "            if phase == \"train\":\n",
    "                history[\"train_loss\"].append(epoch_loss)\n",
    "                history[\"train_acc\"].append(epoch_acc)\n",
    "                print(f\"train | loss={epoch_loss:.4f} acc={epoch_acc:.4f}\")\n",
    "            else:\n",
    "                y_true_np = np.array(y_true_epoch, dtype=int)\n",
    "                y_pred_np = np.array(y_pred_epoch, dtype=int)\n",
    "\n",
    "                val_bal_acc = balanced_accuracy_score(y_true_np, y_pred_np)\n",
    "                val_f1_female = f1_score(\n",
    "                    (y_true_np == IDX_F).astype(int),\n",
    "                    (y_pred_np == IDX_F).astype(int),\n",
    "                    zero_division=0,\n",
    "                )\n",
    "\n",
    "                history[\"val_loss\"].append(epoch_loss)\n",
    "                history[\"val_acc\"].append(epoch_acc)\n",
    "                history[\"val_bal_acc\"].append(val_bal_acc)\n",
    "                history[\"val_f1_female\"].append(val_f1_female)\n",
    "\n",
    "                decision_str = \"argmax\" if USE_ARGMAX_DECISION else f\"thr_f={THRESHOLD_FEMALE}, thr_i={THRESHOLD_INDET}\"\n",
    "                print(\n",
    "                    f\"val   | loss={epoch_loss:.4f} acc={epoch_acc:.4f} \"\n",
    "                    f\"bal_acc={val_bal_acc:.4f} f1_femelle={val_f1_female:.4f} \"\n",
    "                    f\"decision={decision_str}\"\n",
    "                )\n",
    "\n",
    "                scheduler.step(val_f1_female)\n",
    "\n",
    "                if val_f1_female > best_score:\n",
    "                    best_score = float(val_f1_female)\n",
    "                    best_model_wts = copy.deepcopy(model.state_dict())\n",
    "                    torch.save(best_model_wts, os.path.join(OUTPUT_DIR, \"best_model.pth\"))\n",
    "\n",
    "                    best_meta.update({\n",
    "                        \"best_epoch\": epoch + 1,\n",
    "                        \"best_val_f1_female\": float(val_f1_female),\n",
    "                        \"best_val_bal_acc\": float(val_bal_acc),\n",
    "                        \"best_val_acc\": float(epoch_acc),\n",
    "                    })\n",
    "                    with open(os.path.join(OUTPUT_DIR, \"best_meta.json\"), \"w\") as f:\n",
    "                        json.dump(best_meta, f, indent=2)\n",
    "\n",
    "                    print(\"⭐ Best model saved\")\n",
    "\n",
    "    time_elapsed = time.time() - since\n",
    "    print(f\"\\nTraining complete in {time_elapsed/60:.1f} min\")\n",
    "    print(f\"Best F1(femelle) = {best_score:.4f}\")\n",
    "\n",
    "    # 9) Évaluation finale + erreurs\n",
    "    print(\"\\n--- ÉVALUATION FINALE ---\")\n",
    "    model.load_state_dict(best_model_wts)\n",
    "    model.eval()\n",
    "\n",
    "    y_true, y_pred, y_probs, val_paths = [], [], [], []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for inputs, labels, paths in dataloaders[\"val\"]:\n",
    "            inputs = inputs.to(head_device, non_blocking=True)\n",
    "            labels = labels.to(head_device, non_blocking=True)\n",
    "\n",
    "            with torch.cuda.amp.autocast(enabled=use_amp):\n",
    "                outputs = model(inputs)\n",
    "                probs = torch.softmax(outputs, dim=1)\n",
    "\n",
    "            if USE_ARGMAX_DECISION:\n",
    "                _, preds_decision = torch.max(outputs, 1)\n",
    "            else:\n",
    "                preds_decision = predict_with_thresholds(\n",
    "                    probs, IDX_F, IDX_M, IDX_I, THRESHOLD_FEMALE, THRESHOLD_INDET, labels\n",
    "                )\n",
    "\n",
    "            y_true.extend(labels.cpu().numpy().tolist())\n",
    "            y_pred.extend(preds_decision.cpu().numpy().tolist())\n",
    "            y_probs.extend(probs.cpu().numpy().tolist())\n",
    "            val_paths.extend(list(paths))\n",
    "\n",
    "    plot_confusion_matrix(y_true, y_pred, class_names, OUTPUT_DIR)\n",
    "\n",
    "    report = classification_report(y_true, y_pred, target_names=class_names, zero_division=0)\n",
    "    with open(os.path.join(OUTPUT_DIR, \"classification_report.txt\"), \"w\") as f:\n",
    "        f.write(report)\n",
    "    print(report)\n",
    "\n",
    "    plot_history(history, OUTPUT_DIR)\n",
    "\n",
    "    y_true = np.array(y_true, dtype=int)\n",
    "    y_pred = np.array(y_pred, dtype=int)\n",
    "    y_probs = np.array(y_probs, dtype=float)\n",
    "\n",
    "    errors = np.where(y_true != y_pred)[0]\n",
    "    print(f\"Nb erreurs val: {len(errors)} / {len(y_true)}\")\n",
    "\n",
    "    errors_dir = os.path.join(OUTPUT_DIR, \"errors_val\")\n",
    "    os.makedirs(errors_dir, exist_ok=True)\n",
    "\n",
    "    for i in errors:\n",
    "        src = val_paths[i]\n",
    "        true_cls = class_names[y_true[i]]\n",
    "        pred_cls = class_names[y_pred[i]]\n",
    "\n",
    "        conf = y_probs[i][y_pred[i]] * 100\n",
    "        pf = y_probs[i][IDX_F] * 100\n",
    "        pi = y_probs[i][IDX_I] * 100\n",
    "        pm = y_probs[i][IDX_M] * 100\n",
    "\n",
    "        base = os.path.basename(src)\n",
    "        tag = (\n",
    "            f\"idx{i}_true-{true_cls}_pred-{pred_cls}_\"\n",
    "            f\"conf{conf:.1f}_Pf{pf:.1f}_Pi{pi:.1f}_Pm{pm:.1f}\"\n",
    "        )\n",
    "        dst = os.path.join(errors_dir, f\"{tag}__{base}\")\n",
    "        shutil.copy2(src, dst)\n",
    "\n",
    "        print(\n",
    "            f\"  ❌ idx={i} | vrai={true_cls} | pred={pred_cls} | \"\n",
    "            f\"conf={conf:.2f}% | Pf={pf:.2f}% | Pi={pi:.2f}% | Pm={pm:.2f}%\"\n",
    "        )\n",
    "\n",
    "    print(f\"\\nErreurs copiées dans: {errors_dir}\")\n",
    "    print(f\"Tout est sauvegardé dans: {OUTPUT_DIR}\")\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()\n"
   ]
  },
